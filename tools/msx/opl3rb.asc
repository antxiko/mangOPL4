10 CLS:PRINT "OPL3 read-back test"
20 PRINT
30 OUT &HC4,&H10:OUT &HC5,&H55
40 R=INP(&HC5)
50 PRINT "C5 escrito 55, leido &H";HEX$(R)
60 OUT &HC6,&H20:OUT &HC7,&HAA
70 R=INP(&HC7)
80 PRINT "C7 escrito AA, leido &H";HEX$(R)
90 OUT &HC4,&H40:OUT &HC5,&H3C
100 R=INP(&HC5)
110 PRINT "C5 escrito 3C, leido &H";HEX$(R)
120 PRINT
130 PRINT "OK = shadow funciona"
140 PRINT "FF = wrapper no devuelve datos"
150 PRINT
160 PRINT "Pulsa tecla":IF INKEY$="" THEN 160
