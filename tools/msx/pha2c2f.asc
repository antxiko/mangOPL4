10 CLS
20 PRINT "MangOPL4 Wave 2c.2.f - interp + fetch1 audible"
30 OUT &HC6,&H05:OUT &HC7,&H03 :REM NEW + NEW2
40 PRINT "Barrido OCT=1,3,5,7 (FNUM=0)"
50 PRINT "Esperado: tono que SUBE de pitch"
60 PRINT "(no es musical: lee el header del YRW801"
70 PRINT "como audio, pero debe variar con OCT)"
80 PRINT "ENTER para empezar"
90 INPUT A$
100 FOR O=1 TO 7 STEP 2
110 OCT=O*16
120 OUT &H7E,&H20:OUT &H7F,&H00
130 OUT &H7E,&H38:OUT &H7F,OCT
140 OUT &H7E,&H68:OUT &H7F,&H80
150 PRINT "OCT=";O;" key-on";
160 FOR I=1 TO 3000:NEXT I
170 OUT &H7E,&H68:OUT &H7F,&H00
180 PRINT " off"
190 FOR I=1 TO 800:NEXT I
200 NEXT O
210 PRINT "Fin. ENTER para tono fijo OCT=4 (sample real audible)"
220 INPUT A$
230 OUT &H7E,&H20:OUT &H7F,&H00
240 OUT &H7E,&H38:OUT &H7F,&H40
250 OUT &H7E,&H68:OUT &H7F,&H80
260 PRINT "Sonando OCT=4. ENTER para off"
270 INPUT A$
280 OUT &H7E,&H68:OUT &H7F,&H00
290 PRINT "Off"
