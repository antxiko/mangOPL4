10 CLS
20 PRINT "MangOPL4 - timer detect test"
30 PRINT "============================="
40 PRINT
50 OUT &HC4,4:OUT &HC5,&H60
60 OUT &HC4,4:OUT &HC5,&H80
70 S1=INP(&HC4)
80 OUT &HC4,2:OUT &HC5,&HFF
90 OUT &HC4,4:OUT &HC5,&H21
100 FOR I=1 TO 500:NEXT I
110 S2=INP(&HC4)
120 OUT &HC4,4:OUT &HC5,&H60
130 OUT &HC4,4:OUT &HC5,&H80
140 PRINT "Status pre  : &H";HEX$(S1);" (esperado &H00)"
150 PRINT "Status post : &H";HEX$(S2);" (esperado &HC0)"
160 PRINT
170 IF (S1 AND &HE0)=0 AND (S2 AND &HE0)=&HC0 THEN GOTO 200
180 PRINT "Timer NO funciona como esperado."
190 PRINT "VGMPlay no podra detectar OPL3.":GOTO 999
200 PRINT "OK: detector estandar OPL3 -> SI."
210 PRINT "VGMPlay deberia detectarlo."
999 PRINT:PRINT "Pulsa tecla":IF INKEY$="" THEN 999
