1 SCREEN 0:WIDTH 80
10 CLS
20 PRINT "MangOPL4 dbg_crash - snapshot pre-crash"
30 PRINT "Ejecuta TRAS reset MSX desde un cuelgue."
40 OUT &HC6,&H05:OUT &HC7,&H03 :REM NEW + NEW2
50 PRINT
60 PRINT "Snapshot (sobrevivio reset MSX):"
70 OUT &H7E,&HE6:SS=INP(&H7F)
80 OUT &H7E,&HE7:SC=INP(&H7F)
90 OUT &H7E,&HE8:DL=INP(&H7F)
100 OUT &H7E,&HE9:DH=INP(&H7F)
110 OUT &H7E,&HEA:RL=INP(&H7F)
120 OUT &H7E,&HEB:RH=INP(&H7F)
130 OUT &H7E,&HEC:AL=INP(&H7F)
140 OUT &H7E,&HED:AM=INP(&H7F)
150 OUT &H7E,&HEE:AH=INP(&H7F)
160 PRINT "snap_state=";SS
170 PRINT "snap_slot=";SC
180 PRINT "snap_done=";DH*256+DL
190 PRINT "snap_retry=";RH*256+RL
200 PRINT "snap_last_fetch_addr=";AH*65536#+AM*256+AL
210 PRINT
220 PRINT "Estado actual (post reset):"
230 OUT &H7E,&HE0:SL=INP(&H7F)
240 OUT &H7E,&HE2:DCL=INP(&H7F)
250 OUT &H7E,&HE3:DCH=INP(&H7F)
260 PRINT "state=";SL;" done=";DCH*256+DCL
270 PRINT
280 PRINT "Si snap_state=31 -> FPGA cold-booted, no snapshot"
290 PRINT "Si snap_state=7 -> stuck en FETCH_WAIT_A pre-crash"
300 PRINT "Si snap_state=11 -> stuck en FETCH_WAIT_B"
310 PRINT "snap_done/retry pre-crash dan diagnostico"
