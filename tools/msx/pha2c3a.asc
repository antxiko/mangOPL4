10 CLS
20 PRINT "MangOPL4 Wave 2c.3.a - BSRAM state file"
30 OUT &HC6,&H05:OUT &HC7,&H03 :REM NEW + NEW2
40 OUT &H7E,&H20:OUT &H7F,&H00
50 OUT &H7E,&H38:OUT &H7F,&H40 :REM OCT=4
60 OUT &H7E,&H68:OUT &H7F,&H80 :REM key-on
70 FOR I=1 TO 1000:NEXT I
80 OUT &H7E,&H68:OUT &H7F,&H00 :REM key-off (phase_acc congelado)
90 FOR I=1 TO 200:NEXT I
100 OUT &H7E,&HFC:A0=INP(&H7F)
110 OUT &H7E,&HFD:A1=INP(&H7F)
120 OUT &H7E,&HFE:A2=INP(&H7F)
130 OUT &H7E,&HFF:A3=INP(&H7F)
140 OUT &H7E,&HF0:B0=INP(&H7F)
150 OUT &H7E,&HF1:B1=INP(&H7F)
160 OUT &H7E,&HF2:B2=INP(&H7F)
170 OUT &H7E,&HF3:B3=INP(&H7F)
180 PRINT "Directo  FC-FF: ";HEX$(A3);HEX$(A2);HEX$(A1);HEX$(A0)
190 PRINT "BSRAM    F0-F3: ";HEX$(B3);HEX$(B2);HEX$(B1);HEX$(B0)
200 IF A0=B0 AND A1=B1 AND A2=B2 AND A3=B3 THEN PRINT "PASS: BSRAM coincide" ELSE PRINT "FAIL: BSRAM difiere"
