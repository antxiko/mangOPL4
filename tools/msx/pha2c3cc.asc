1 SCREEN 0:WIDTH 80
10 CLS
20 PRINT "MangOPL4 2c.3.R3 - EG attack tests (varios AR)"
30 OUT &HC6,&H05:OUT &HC7,&H03 :REM NEW + NEW2
40 OUT &H7E,&H20:OUT &H7F,&H00 :REM FN low = 0
50 OUT &H7E,&H38:OUT &H7F,&H40 :REM OCT=4
60 OUT &H7E,&H50:OUT &H7F,&H00 :REM TL=0 (full)
70 OUT &H7E,&H98:OUT &H7F,&H00 :REM DL=0 D2R=0 (no decay tras attack)
80 OUT &H7E,&HB0:OUT &H7F,&H0F :REM RR=15 (release rapido tras key-off)
90 PRINT
100 PRINT "A) AR=15: instant attack (=full vol inmediato)"
110 OUT &H7E,&H80:OUT &H7F,&HF0
120 PRINT "ENTER para key-on/off (espera segundo y key-off)"
130 INPUT A$
140 OUT &H7E,&H68:OUT &H7F,&H80
150 FOR I=1 TO 4000:NEXT I
160 OUT &H7E,&H68:OUT &H7F,&H00
170 PRINT
180 PRINT "B) AR=8: attack ~46ms (apenas perceptible)"
190 OUT &H7E,&H80:OUT &H7F,&H80
200 PRINT "ENTER":INPUT A$
210 OUT &H7E,&H68:OUT &H7F,&H80
220 FOR I=1 TO 4000:NEXT I
230 OUT &H7E,&H68:OUT &H7F,&H00
240 PRINT
250 PRINT "C) AR=4: attack ~740ms (gradiente claro)"
260 OUT &H7E,&H80:OUT &H7F,&H40
270 PRINT "ENTER":INPUT A$
280 OUT &H7E,&H68:OUT &H7F,&H80
290 FOR I=1 TO 8000:NEXT I
300 OUT &H7E,&H68:OUT &H7F,&H00
310 PRINT
320 PRINT "D) AR=2: attack ~3 seg (super lento)"
330 OUT &H7E,&H80:OUT &H7F,&H20
340 PRINT "ENTER":INPUT A$
350 OUT &H7E,&H68:OUT &H7F,&H80
360 FOR I=1 TO 16000:NEXT I
370 OUT &H7E,&H68:OUT &H7F,&H00
380 PRINT
390 PRINT "E) AR=0: NUNCA ataca = silencio total"
400 OUT &H7E,&H80:OUT &H7F,&H00
410 PRINT "ENTER":INPUT A$
420 OUT &H7E,&H68:OUT &H7F,&H80
430 FOR I=1 TO 6000:NEXT I
440 OUT &H7E,&H68:OUT &H7F,&H00
450 PRINT
460 PRINT "Fin. Esperado:"
470 PRINT " A=instant, B=casi instant, C=ramp 3/4s,"
480 PRINT " D=ramp 3s lento clarisimo, E=mudo"
