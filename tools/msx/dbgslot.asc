1 SCREEN 0:WIDTH 80
10 CLS
20 PRINT "MangOPL4 R2 - slot_serial FSM debug"
30 OUT &HC6,&H05:OUT &HC7,&H03 :REM NEW + NEW2
40 PRINT
50 PRINT "T0 (sin key-on):"
60 OUT &H7E,&HE0:S0=INP(&H7F)
70 OUT &H7E,&HE1:C0=INP(&H7F)
80 OUT &H7E,&HE2:DL0=INP(&H7F)
90 OUT &H7E,&HE3:DH0=INP(&H7F)
95 OUT &H7E,&HE4:RL0=INP(&H7F)
96 OUT &H7E,&HE5:RH0=INP(&H7F)
100 PRINT "state=";S0;" done=";DH0*256+DL0;" retry=";RH0*256+RL0
110 PRINT
120 PRINT "Pulso key-on slot 0 OCT=4..."
130 OUT &H7E,&H20:OUT &H7F,&H00
140 OUT &H7E,&H38:OUT &H7F,&H40
150 OUT &H7E,&H68:OUT &H7F,&H80
160 FOR I=1 TO 500:NEXT I
180 PRINT "T1 (post key-on):"
190 OUT &H7E,&HE0:S1=INP(&H7F)
210 OUT &H7E,&HE2:DL1=INP(&H7F)
220 OUT &H7E,&HE3:DH1=INP(&H7F)
225 OUT &H7E,&HE4:RL1=INP(&H7F)
226 OUT &H7E,&HE5:RH1=INP(&H7F)
230 PRINT "state=";S1;" done=";DH1*256+DL1;" retry=";RH1*256+RL1
240 PRINT
250 PRINT "Espera 2 seg..."
260 FOR I=1 TO 4000:NEXT I
280 PRINT "T2 (2 seg):"
290 OUT &H7E,&HE0:S2=INP(&H7F)
310 OUT &H7E,&HE2:DL2=INP(&H7F)
320 OUT &H7E,&HE3:DH2=INP(&H7F)
325 OUT &H7E,&HE4:RL2=INP(&H7F)
326 OUT &H7E,&HE5:RH2=INP(&H7F)
330 PRINT "state=";S2;" done=";DH2*256+DL2;" retry=";RH2*256+RL2
340 PRINT
350 PRINT "phase_acc slot 0:"
360 OUT &H7E,&HFC:P0=INP(&H7F)
370 OUT &H7E,&HFD:P1=INP(&H7F)
380 OUT &H7E,&HFE:P2=INP(&H7F)
390 OUT &H7E,&HFF:P3=INP(&H7F)
400 PRINT "phase=";P3*16777216#+P2*65536+P1*256+P0
420 OUT &H7E,&H68:OUT &H7F,&H00 :REM key-off
430 PRINT "Esperado:"
440 PRINT " done incrementando ~88000 entre T1 y T2"
450 PRINT " retry incrementando si arbiter race"
460 PRINT " phase avanzando con OCT=4"
