1 SCREEN 0:WIDTH 80
10 CLS
20 PRINT "R5.a-infra - lookup wave_num funciona?"
30 PRINT "BSRAM con fakes: wave_num N apunta a 0x101200 + N*0x2000"
40 PRINT "Esperado: 6 wave_nums distintos suenan DISTINTO entre si"
50 PRINT ""
60 OUT &HC6,&H05:OUT &HC7,&H03 :REM NEW + NEW2
70 OUT &H7E,&H38:OUT &H7F,&H40 :REM OCT=4
80 OUT &H7E,&H50:OUT &H7F,&H00 :REM TL=0
90 OUT &H7E,&H80:OUT &H7F,&HF0 :REM AR=15 D1R=0
100 OUT &H7E,&H98:OUT &H7F,&H00 :REM DL=0 D2R=0
110 OUT &H7E,&HB0:OUT &H7F,&H0F :REM RR=15
120 PRINT "Setup OK. Pulsa ENTER para sonar 6 wave_num distintos..."
130 INPUT A$
140 FOR W=0 TO 5
150 PRINT "wave_num = ";W
160 OUT &H7E,&H08:OUT &H7F,W :REM wave_num low
170 OUT &H7E,&H20:OUT &H7F,&H00 :REM wave_num bit 8 = 0, FN low = 0
180 FOR D=1 TO 200:NEXT D :REM espera para que lookup BSRAM acabe
190 OUT &H7E,&H68:OUT &H7F,&H80 :REM key_on
200 FOR D=1 TO 6000:NEXT D :REM ~1.5 sec
210 OUT &H7E,&H68:OUT &H7F,&H00 :REM key_off
220 FOR D=1 TO 2000:NEXT D
230 NEXT W
240 PRINT ""
250 PRINT "FIN. Reportar:"
260 PRINT "  - Los 6 wave_nums suenan DISTINTOS entre si? (clave)"
270 PRINT "  - Cada cold boot da mismo resultado?"
