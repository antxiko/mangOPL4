10 CLS
20 PRINT "MangOPL4 Wave 2c.2.c - FNUM/OCT desde regfile"
30 OUT &HC6,&H05:OUT &HC7,&H03 :REM enable NEW + NEW2
40 REM TEST 1: FNUM=0, OCT=0 (phase_inc esperado pequeno)
50 OUT &H7E,&H20:OUT &H7F,&H00 :REM reg 0x20 = 0 -> FN[6:0]=0
60 OUT &H7E,&H38:OUT &H7F,&H00 :REM reg 0x38 = 0 -> FN[9:7]=0, OCT=0
70 OUT &H7E,&H68:OUT &H7F,&H80 :REM key-on slot 0
80 FOR I=1 TO 1000:NEXT I
90 PRINT "T1 FN=0 OCT=0:"
100 GOSUB 500
110 OUT &H7E,&H68:OUT &H7F,&H00 :REM key-off
120 FOR I=1 TO 200:NEXT I
130 REM TEST 2: FNUM=0x3FF, OCT=0 (phase_inc max para OCT=0)
140 OUT &H7E,&H20:OUT &H7F,&HFE :REM reg 0x20 = 0xFE -> FN[6:0]=0x7F
150 OUT &H7E,&H38:OUT &H7F,&H07 :REM reg 0x38 = 0x07 -> FN[9:7]=7, OCT=0
160 OUT &H7E,&H68:OUT &H7F,&H80
170 FOR I=1 TO 1000:NEXT I
180 PRINT "T2 FN=3FF OCT=0:"
190 GOSUB 500
200 OUT &H7E,&H68:OUT &H7F,&H00
210 FOR I=1 TO 200:NEXT I
220 REM TEST 3: FNUM=0, OCT=4 (shift left 4, mas rapido)
230 OUT &H7E,&H20:OUT &H7F,&H00
240 OUT &H7E,&H38:OUT &H7F,&H40 :REM bits[7:4]=4 -> OCT=4
250 OUT &H7E,&H68:OUT &H7F,&H80
260 FOR I=1 TO 1000:NEXT I
270 PRINT "T3 FN=0 OCT=4:"
280 GOSUB 500
290 OUT &H7E,&H68:OUT &H7F,&H00
300 PRINT
310 PRINT "esperado: T2 > T1 (FN mayor)"
320 PRINT "          T3 > T1 (OCT mayor, shift)"
330 END
500 OUT &H7E,&HFC:PRINT "[7:0]=";HEX$(INP(&H7F));" ";
510 OUT &H7E,&HFD:PRINT "[15:8]=";HEX$(INP(&H7F));" ";
520 OUT &H7E,&HFE:PRINT "[23:16]=";HEX$(INP(&H7F));" ";
530 OUT &H7E,&HFF:PRINT "[31:24]=";HEX$(INP(&H7F))
540 RETURN
