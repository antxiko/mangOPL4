10 CLS
20 PRINT "MangOPL4 Wave 2c.3.j - DADSR completo"
30 OUT &HC6,&H05:OUT &HC7,&H03 :REM NEW + NEW2
40 OUT &H7E,&H20:OUT &H7F,&H00 :REM FNUM=0
50 OUT &H7E,&H38:OUT &H7F,&H40 :REM OCT=4
60 OUT &H7E,&H50:OUT &H7F,&H00 :REM TL=0
70 PRINT "Test 1: ataque instant + release lento"
80 PRINT "AR=15, D1R=0, DL=0, D2R=0, RR=4 (release ~500ms)"
90 PRINT "Key-on, esperar, key-off, oir fade-out"
100 PRINT "ENTER para empezar"
110 INPUT A$
120 OUT &H7E,&H80:OUT &H7F,&HF0 :REM AR=15 D1R=0
130 OUT &H7E,&H98:OUT &H7F,&H00 :REM DL=0 D2R=0
140 OUT &H7E,&HB0:OUT &H7F,&H04 :REM RC=0 RR=4
150 OUT &H7E,&H68:OUT &H7F,&H80
160 PRINT "key-on (sostenido)"
170 FOR I=1 TO 3000:NEXT I
180 OUT &H7E,&H68:OUT &H7F,&H00
190 PRINT "key-off (oir fade-out)"
200 FOR I=1 TO 3000:NEXT I
210 PRINT ""
220 PRINT "Test 2: DEC1 -> DL audible"
230 PRINT "AR=15, D1R=8, DL=8 (dec rapido a DL ~50%)"
240 PRINT "ENTER"
250 INPUT A$
260 OUT &H7E,&H80:OUT &H7F,&HF8 :REM AR=15 D1R=8
270 OUT &H7E,&H98:OUT &H7F,&H80 :REM DL=8 D2R=0
280 OUT &H7E,&HB0:OUT &H7F,&H08 :REM RR=8
290 OUT &H7E,&H68:OUT &H7F,&H80
300 FOR I=1 TO 4000:NEXT I
310 OUT &H7E,&H68:OUT &H7F,&H00
320 FOR I=1 TO 2000:NEXT I
330 PRINT "Fin"
