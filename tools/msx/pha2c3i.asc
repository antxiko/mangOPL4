10 CLS
20 PRINT "MangOPL4 Wave 2c.3.i - AR (Attack Rate)"
30 OUT &HC6,&H05:OUT &HC7,&H03 :REM NEW + NEW2
40 OUT &H7E,&H20:OUT &H7F,&H00 :REM FNUM=0
50 OUT &H7E,&H38:OUT &H7F,&H40 :REM OCT=4
60 OUT &H7E,&H50:OUT &H7F,&H00 :REM TL=0
70 OUT &H7E,&H98:OUT &H7F,&H00 :REM DL=0
80 PRINT "Barrido AR=15,12,8,4,2 (ataque cada vez mas lento)"
90 PRINT "AR=15 instant, AR=2 muy gradual (audible la rampa)"
100 PRINT "ENTER para empezar"
110 INPUT A$
120 FOR R=15 TO 2 STEP -3
130 OUT &H7E,&H80:OUT &H7F,R*16
140 OUT &H7E,&H68:OUT &H7F,&H80
150 PRINT "AR=";R
160 FOR I=1 TO 4000:NEXT I
170 OUT &H7E,&H68:OUT &H7F,&H00
180 FOR I=1 TO 1000:NEXT I
190 NEXT R
200 PRINT "Fin"
