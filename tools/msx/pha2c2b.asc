10 CLS
20 PRINT "MangOPL4 Wave 2c.2.b - phase observable"
30 OUT &HC6,&H05:OUT &HC7,&H03 :REM enable NEW + NEW2
40 PRINT "antes de key-on (esperado todo 0):"
50 GOSUB 200
60 PRINT
70 PRINT "key-on slot 0..."
80 OUT &H7E,&H68:OUT &H7F,&H80
90 FOR I=1 TO 1000:NEXT I :REM esperar para que phase avance
100 PRINT "tras key-on + delay (esperado bytes >0 creciendo):"
110 GOSUB 200
120 PRINT
130 FOR I=1 TO 2000:NEXT I :REM mas delay
140 PRINT "mas delay (bytes deben ser mayores):"
150 GOSUB 200
160 PRINT
170 PRINT "key-off"
180 OUT &H7E,&H68:OUT &H7F,&H00
190 END
200 REM leer phase_acc[31:0] = regs FC..FF
210 OUT &H7E,&HFC:PRINT "[7:0]=";HEX$(INP(&H7F));" ";
220 OUT &H7E,&HFD:PRINT "[15:8]=";HEX$(INP(&H7F));" ";
230 OUT &H7E,&HFE:PRINT "[23:16]=";HEX$(INP(&H7F));" ";
240 OUT &H7E,&HFF:PRINT "[31:24]=";HEX$(INP(&H7F))
250 RETURN
