10 CLS
20 PRINT "MangOPL4 2c.3.bb - TL extremos"
30 OUT &HC6,&H05:OUT &HC7,&H03 :REM NEW + NEW2
40 OUT &H7E,&H20:OUT &H7F,&H00 :REM FNUM=0
50 OUT &H7E,&H38:OUT &H7F,&H40 :REM OCT=4
60 PRINT "Test 1: TL=0 (full vol) ~2 seg"
70 PRINT "ENTER"
80 INPUT A$
90 OUT &H7E,&H50:OUT &H7F,&H00 :REM TL=0
100 OUT &H7E,&H68:OUT &H7F,&H80
110 FOR I=1 TO 8000:NEXT I
120 OUT &H7E,&H68:OUT &H7F,&H00
130 PRINT ""
140 PRINT "Test 2: TL=127 (silencio) ~2 seg"
150 PRINT "ENTER"
160 INPUT A$
170 OUT &H7E,&H50:OUT &H7F,&HFE :REM TL=127 (bits 7:1 = 0x7F)
180 OUT &H7E,&H68:OUT &H7F,&H80
190 FOR I=1 TO 8000:NEXT I
200 OUT &H7E,&H68:OUT &H7F,&H00
210 PRINT "Fin"
