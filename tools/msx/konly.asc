10 CLS
20 PRINT "Phase 1 isolation: key-on only, no FA/FB read"
30 OUT &HC6,&H05:OUT &HC7,&H03 :REM NEW + NEW2
40 PRINT "key-on slot 0..."
50 OUT &H7E,&H20:OUT &H7F,&H00
60 OUT &H7E,&H38:OUT &H7F,&H00
70 OUT &H7E,&H68:OUT &H7F,&H80 :REM KEY ON
80 FOR I=1 TO 500:NEXT I
90 OUT &H7E,&H68:OUT &H7F,&H00 :REM KEY OFF
100 PRINT "key-off, OK"
