10 CLS
20 PRINT "MangOPL4 Wave 2b.2 - memory port"
30 PRINT "escribiendo 16 bytes en SRAM..."
40 OUT &HC6,&H05:OUT &HC7,&H03 :REM enable NEW + NEW2
50 OUT &H7E,&H03:OUT &H7F,&H20:REM ptr hi = 0x20
60 OUT &H7E,&H04:OUT &H7F,&H00:REM ptr mid = 0x00
70 OUT &H7E,&H05:OUT &H7F,&H00:REM ptr lo = 0x00
80 OUT &H7E,&H06
90 FOR I=0 TO 15:OUT &H7F,I*17:NEXT I
100 PRINT "leyendo de vuelta..."
110 OUT &H7E,&H03:OUT &H7F,&H20
120 OUT &H7E,&H04:OUT &H7F,&H00
130 OUT &H7E,&H05:OUT &H7F,&H00
140 OUT &H7E,&H06
150 FOR I=0 TO 15:PRINT HEX$(INP(&H7F));" ";:NEXT I
160 PRINT
170 PRINT "esperado: 0 11 22 33 44 55 66 77 88 99 AA BB CC DD EE FF"
