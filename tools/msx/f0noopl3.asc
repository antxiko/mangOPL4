1 SCREEN 0:WIDTH 80
10 CLS
20 PRINT "Fase 0 - test Wave SIN core OPL3"
30 PRINT "Si Wave es consistente entre boots, OPL3 contamina."
40 PRINT "Si Wave sigue lottery, bug es del Wave en si."
50 PRINT ""
60 OUT &HC6,&H05:OUT &HC7,&H03 :REM NEW + NEW2
70 OUT &H7E,&H20:OUT &H7F,&H00 :REM FN low = 0
80 OUT &H7E,&H38:OUT &H7F,&H40 :REM OCT=4
90 OUT &H7E,&H50:OUT &H7F,&H00 :REM TL=0 (full vol)
100 OUT &H7E,&H80:OUT &H7F,&HF0 :REM AR=15 D1R=0
110 OUT &H7E,&H98:OUT &H7F,&H00 :REM DL=0 D2R=0
120 OUT &H7E,&HB0:OUT &H7F,&H0F :REM PRVB=0 RR=15
130 PRINT "Setup OK. Pulsa ENTER para test 1..."
140 INPUT A$
150 PRINT "Test 1 KEYON (~3 sec)"
160 OUT &H7E,&H68:OUT &H7F,&H80
170 FOR I=1 TO 12000:NEXT I
180 OUT &H7E,&H68:OUT &H7F,&H00
190 PRINT "Pulsa ENTER para test 2..."
200 INPUT A$
210 PRINT "Test 2 KEYON (~3 sec)"
220 OUT &H7E,&H68:OUT &H7F,&H80
230 FOR I=1 TO 12000:NEXT I
240 OUT &H7E,&H68:OUT &H7F,&H00
250 PRINT "Pulsa ENTER para test 3..."
260 INPUT A$
270 PRINT "Test 3 KEYON (~3 sec)"
280 OUT &H7E,&H68:OUT &H7F,&H80
290 FOR I=1 TO 12000:NEXT I
300 OUT &H7E,&H68:OUT &H7F,&H00
310 PRINT ""
320 PRINT "FIN. Reportar:"
330 PRINT "  - Los 3 tests suenan IGUAL? (clave!)"
340 PRINT "  - MoonBlaster FM no debe sonar (esperado, OPL3 off)"
