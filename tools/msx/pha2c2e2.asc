10 CLS
20 PRINT "MangOPL4 Wave 2c.2.e.2 - fetch1 YRW801"
30 OUT &HC6,&H05:OUT &HC7,&H03 :REM NEW + NEW2
40 PRINT "FNUM/OCT=0, key-on slot 0..."
50 OUT &H7E,&H20:OUT &H7F,&H00
60 OUT &H7E,&H38:OUT &H7F,&H00
70 OUT &H7E,&H68:OUT &H7F,&H80
80 FOR I=1 TO 500:NEXT I
90 OUT &H7E,&HFA:A=INP(&H7F)
100 OUT &H7E,&HFB:B=INP(&H7F)
110 PRINT "fetch byte_a=";HEX$(A);" byte_b=";HEX$(B)
120 PRINT "esperado: bytes del YRW801 (no 0x80=silencio)"
130 OUT &H7E,&H68:OUT &H7F,&H00
140 PRINT "Off"
