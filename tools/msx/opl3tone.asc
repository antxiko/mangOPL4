10 CLS
20 PRINT "MangOPL4 - tono 440 Hz"
30 PRINT
40 OUT &HC6,5:OUT &HC7,1
50 OUT &HC4,&H20:OUT &HC5,1
60 OUT &HC4,&H40:OUT &HC5,&H10
70 OUT &HC4,&H60:OUT &HC5,&HF0
80 OUT &HC4,&H80:OUT &HC5,&H77
90 OUT &HC4,&HE0:OUT &HC5,0
100 OUT &HC4,&H23:OUT &HC5,1
110 OUT &HC4,&H43:OUT &HC5,0
120 OUT &HC4,&H63:OUT &HC5,&HF0
130 OUT &HC4,&H83:OUT &HC5,&H77
140 OUT &HC4,&HE3:OUT &HC5,0
150 OUT &HC4,&HC0:OUT &HC5,&HCB
160 OUT &HC4,&HA0:OUT &HC5,&H44
170 OUT &HC4,&HB0:OUT &HC5,&H32
180 PRINT "Suena un tono?"
190 PRINT "S=si, N=no"
200 A$=INPUT$(1)
210 OUT &HC4,&HB0:OUT &HC5,&H12
220 IF A$="S" OR A$="s" THEN PRINT "OK, audio path funciona"
230 IF A$="N" OR A$="n" THEN PRINT "Audio path roto - debug"
240 PRINT:PRINT "Pulsa tecla":IF INKEY$="" THEN 240
