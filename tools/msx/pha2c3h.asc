10 CLS
20 PRINT "MangOPL4 Wave 2c.3.h - DL (EG sustain level)"
30 OUT &HC6,&H05:OUT &HC7,&H03 :REM NEW + NEW2
40 OUT &H7E,&H20:OUT &H7F,&H00 :REM FNUM=0
50 OUT &H7E,&H38:OUT &H7F,&H40 :REM OCT=4
60 OUT &H7E,&H50:OUT &H7F,&H00 :REM TL=0
70 PRINT "Barrido DL=0,4,8,12,15 (volumen decreciente por EG)"
80 PRINT "ENTER para empezar"
90 INPUT A$
100 FOR D=0 TO 15 STEP 4
110 OUT &H7E,&H98:OUT &H7F,D*16
120 OUT &H7E,&H68:OUT &H7F,&H80
130 PRINT "DL=";D
140 FOR I=1 TO 2500:NEXT I
150 OUT &H7E,&H68:OUT &H7F,&H00
160 FOR I=1 TO 600:NEXT I
170 NEXT D
180 OUT &H7E,&H98:OUT &H7F,&HF0 :REM DL=15
190 OUT &H7E,&H68:OUT &H7F,&H80
200 PRINT "DL=15 (max EG atten)"
210 FOR I=1 TO 2500:NEXT I
220 OUT &H7E,&H68:OUT &H7F,&H00
230 PRINT "Fin"
