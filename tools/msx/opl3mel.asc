10 CLS
20 PRINT "MangOPL4 - escala (ESC stop)"
30 DIM F(8),B(8)
40 F(1)=345:B(1)=4
50 F(2)=387:B(2)=4
60 F(3)=434:B(3)=4
70 F(4)=460:B(4)=4
80 F(5)=517:B(5)=4
90 F(6)=580:B(6)=4
100 F(7)=651:B(7)=4
110 F(8)=345:B(8)=5
120 OUT &HC6,5:OUT &HC7,1
130 OUT &HC4,&H20:OUT &HC5,1
140 OUT &HC4,&H40:OUT &HC5,&H10
150 OUT &HC4,&H60:OUT &HC5,&HF0
160 OUT &HC4,&H80:OUT &HC5,&H77
170 OUT &HC4,&HE0:OUT &HC5,0
180 OUT &HC4,&H23:OUT &HC5,1
190 OUT &HC4,&H43:OUT &HC5,0
200 OUT &HC4,&H63:OUT &HC5,&HF0
210 OUT &HC4,&H83:OUT &HC5,&H77
220 OUT &HC4,&HE3:OUT &HC5,0
230 OUT &HC4,&HC0:OUT &HC5,&HCB
240 FOR N=1 TO 8
250 LO=F(N) AND 255
260 HI=INT(F(N)/256)+(B(N)*4)
270 OUT &HC4,&HA0:OUT &HC5,LO
280 OUT &HC4,&HB0:OUT &HC5,HI+&H20
290 FOR I=1 TO 250:NEXT I
300 OUT &HC4,&HB0:OUT &HC5,HI
310 FOR I=1 TO 40:NEXT I
320 IF INKEY$=CHR$(27) THEN 360
330 NEXT N
340 GOTO 240
360 OUT &HC4,&HB0:OUT &HC5,0
370 PRINT "Fin"
380 END
