10 CLS
20 PRINT "MangOPL4 Wave 2c.2.d - pitch via phase"
30 PRINT "cargando 256 bytes sine..."
40 OUT &HC6,&H05:OUT &HC7,&H03 :REM NEW + NEW2
50 OUT &H7E,&H03:OUT &H7F,&H20
60 OUT &H7E,&H04:OUT &H7F,&H00
70 OUT &H7E,&H05:OUT &H7F,&H00
80 OUT &H7E,&H06
90 PI=3.14159265
100 FOR I=0 TO 255
110 X=INT(128+126*SIN(I*2*PI/256))
120 IF X<0 THEN X=0
130 IF X>255 THEN X=255
140 OUT &H7F,X
150 NEXT I
160 PRINT "FNUM=0 OCT=0 (baseline ~172Hz). ENTER":INPUT A$
170 OUT &H7E,&H20:OUT &H7F,&H00
180 OUT &H7E,&H38:OUT &H7F,&H00
190 OUT &H7E,&H68:OUT &H7F,&H80
200 PRINT "ENTER siguiente":INPUT A$
210 OUT &H7E,&H68:OUT &H7F,&H00
220 PRINT "FNUM=3FF OCT=0 (~344Hz, doble). ENTER":INPUT A$
230 OUT &H7E,&H20:OUT &H7F,&HFE
240 OUT &H7E,&H38:OUT &H7F,&H07
250 OUT &H7E,&H68:OUT &H7F,&H80
260 PRINT "ENTER siguiente":INPUT A$
270 OUT &H7E,&H68:OUT &H7F,&H00
280 PRINT "FNUM=0 OCT=4 (~2.7kHz, x16). ENTER":INPUT A$
290 OUT &H7E,&H20:OUT &H7F,&H00
300 OUT &H7E,&H38:OUT &H7F,&H40
310 OUT &H7E,&H68:OUT &H7F,&H80
320 PRINT "ENTER off":INPUT A$
330 OUT &H7E,&H68:OUT &H7F,&H00
340 PRINT "Off"
