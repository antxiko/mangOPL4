10 CLS
20 PRINT "MangOPL4 Wave 2b.4 - YRW801 dump"
30 PRINT "leyendo bytes 0x00-0x1F del YRW801..."
40 OUT &HC6,&H05:OUT &HC7,&H03 :REM enable NEW + NEW2
50 OUT &H7E,&H03:OUT &H7F,&H00:REM ptr hi = 0x00
60 OUT &H7E,&H04:OUT &H7F,&H00:REM ptr mid = 0x00
70 OUT &H7E,&H05:OUT &H7F,&H00:REM ptr lo = 0x00
80 OUT &H7E,&H06
90 FOR I=0 TO 31:PRINT HEX$(INP(&H7F));" ";:NEXT I
100 PRINT
110 PRINT "esperado: bytes variados si YRW801 OK"
120 PRINT "todo FF: flash vacia o bootloader fallo"
130 PRINT "todo 00: RAM clear pero no copy"
