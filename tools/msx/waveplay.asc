10 CLS
20 PRINT "MangOPL4 Wave 2b.3 - playback"
30 PRINT "cargando 256 bytes sine..."
40 OUT &HC6,&H05:OUT &HC7,&H03 :REM NEW + NEW2
50 OUT &H7E,&H03:OUT &H7F,&H20
60 OUT &H7E,&H04:OUT &H7F,&H00
70 OUT &H7E,&H05:OUT &H7F,&H00
80 OUT &H7E,&H06
90 PI=3.14159265
100 FOR I=0 TO 255
110 X=INT(128+126*SIN(I*2*PI/256))
120 IF X<0 THEN X=0
130 IF X>255 THEN X=255
140 OUT &H7F,X
150 NEXT I
160 PRINT "ENTER para tono ON"
170 INPUT A$
180 OUT &H7E,&H68:OUT &H7F,&H80
190 PRINT "tono ~172 Hz. ENTER para off"
200 INPUT A$
210 OUT &H7F,&H00
220 PRINT "Off"
