10 CLS
20 PRINT "MangOPL4 Wave 2c.3.g - TL atenuacion slot 0"
30 OUT &HC6,&H05:OUT &HC7,&H03 :REM NEW + NEW2
40 OUT &H7E,&H20:OUT &H7F,&H00 :REM FNUM=0
50 OUT &H7E,&H38:OUT &H7F,&H40 :REM OCT=4
60 PRINT "Barrido TL=0,16,32,48,64,96 (volumen decreciente)"
70 PRINT "TL=0=full, TL=127=silencio. Esperado: cada vez mas bajo"
80 PRINT "ENTER para empezar"
90 INPUT A$
100 FOR T=0 TO 96 STEP 16
110 OUT &H7E,&H50:OUT &H7F,T*2 :REM TL en bits [7:1]
120 OUT &H7E,&H68:OUT &H7F,&H80 :REM key-on
130 PRINT "TL=";T
140 FOR I=1 TO 2500:NEXT I
150 OUT &H7E,&H68:OUT &H7F,&H00 :REM key-off
160 FOR I=1 TO 600:NEXT I
170 NEXT T
180 PRINT "Fin"
