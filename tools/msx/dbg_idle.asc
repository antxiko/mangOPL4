1 SCREEN 0:WIDTH 80
10 CLS
20 PRINT "MangOPL4 dbg_idle - FSM en idle SIN key_on"
30 OUT &HC6,&H05:OUT &HC7,&H03 :REM NEW + NEW2
40 PRINT
50 PRINT "T0 (sin key_on):"
60 OUT &H7E,&HE0:S0=INP(&H7F)
70 OUT &H7E,&HE2:DL0=INP(&H7F)
80 OUT &H7E,&HE3:DH0=INP(&H7F)
85 OUT &H7E,&HE4:RL0=INP(&H7F)
86 OUT &H7E,&HE5:RH0=INP(&H7F)
90 D0=DH0*256+DL0:R0=RH0*256+RL0
100 PRINT "state=";S0;" done=";D0;" retry=";R0
110 PRINT
120 PRINT "Espera 2 seg (key_on sigue OFF)..."
130 FOR I=1 TO 4000:NEXT I
140 PRINT
150 PRINT "T1 (2 seg):"
160 OUT &H7E,&HE0:S1=INP(&H7F)
170 OUT &H7E,&HE2:DL1=INP(&H7F)
180 OUT &H7E,&HE3:DH1=INP(&H7F)
185 OUT &H7E,&HE4:RL1=INP(&H7F)
186 OUT &H7E,&HE5:RH1=INP(&H7F)
190 D1=DH1*256+DL1:R1=RH1*256+RL1
200 PRINT "state=";S1;" done=";D1;" retry=";R1
210 PRINT
220 PRINT "Delta done=";D1-D0
230 PRINT "Esperado: ~88000 (44 kHz * 2 seg)"
240 PRINT "Si delta=0, FSM atascado en estado=";S1
250 PRINT "Si delta cercano a 88000, FSM idle OK"
