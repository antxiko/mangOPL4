10 SCREEN 0:WIDTH 40:CLS
20 PRINT "MangOPL4 - OPL3 detect"
30 PRINT "======================"
40 PRINT
50 A=INP(&HC4):B=INP(&HC5)
60 C=INP(&HC6):D=INP(&HC7)
70 PRINT "C4h status: &H";HEX$(A)
80 PRINT "C5h       : &H";HEX$(B)
90 PRINT "C6h       : &H";HEX$(C)
100 PRINT "C7h       : &H";HEX$(D)
110 PRINT
120 IF A=255 AND B=255 AND C=255 AND D=255 THEN GOTO 200
130 IF A=255 THEN GOTO 220
140 IF B<>255 OR C<>255 OR D<>255 THEN GOTO 240
150 PRINT "OK: cartucho responde C4h"
160 PRINT "OPL3 wrapper detectado."
170 IF A=0 THEN PRINT "Status=00, timers off"
180 GOTO 999
200 PRINT "Todo FF: cartucho NO responde"
210 GOTO 999
220 PRINT "C4h=FF pero hay respuesta"
230 PRINT "decode al reves":GOTO 999
240 PRINT "C4-7 todos contestan"
250 PRINT "BUSDIR_n bug":GOTO 999
999 PRINT:PRINT "Pulsa tecla":
1000 IF INKEY$="" THEN 1000
