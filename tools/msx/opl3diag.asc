10 SCREEN 0:WIDTH 40:CLS
20 PRINT "MangOPL4 - diag completo"
30 PRINT "========================"
40 PRINT
50 PRINT "[1] Lectura puertos (cold)"
60 PRINT "C4=";HEX$(INP(&HC4));" C5=";HEX$(INP(&HC5));
70 PRINT " C6=";HEX$(INP(&HC6));" C7=";HEX$(INP(&HC7))
80 PRINT "7E=";HEX$(INP(&H7E));" 7F=";HEX$(INP(&H7F))
90 PRINT "(C4 OPL3 status, 7E/7F Wave PCM)"
100 PRINT
110 PRINT "[2] Timer1 detect"
120 OUT &HC4,4:OUT &HC5,&H60
130 OUT &HC4,4:OUT &HC5,&H80
140 P=INP(&HC4)
150 OUT &HC4,2:OUT &HC5,&HFF
160 OUT &HC4,4:OUT &HC5,&H21
170 FOR I=1 TO 500:NEXT I
180 Q=INP(&HC4)
190 OUT &HC4,4:OUT &HC5,&H60
200 OUT &HC4,4:OUT &HC5,&H80
210 PRINT "T1 pre=";HEX$(P);" post=";HEX$(Q);
220 IF (P AND &HE0)=0 AND (Q AND &HE0)=&HC0 THEN PRINT " OK" ELSE PRINT " FAIL"
230 PRINT
240 PRINT "[3] Timer2 detect"
250 OUT &HC4,4:OUT &HC5,&H60
260 OUT &HC4,4:OUT &HC5,&H80
270 P=INP(&HC4)
280 OUT &HC4,3:OUT &HC5,&HFF
290 OUT &HC4,4:OUT &HC5,&H42
300 FOR I=1 TO 2000:NEXT I
310 Q=INP(&HC4)
320 OUT &HC4,4:OUT &HC5,&H60
330 OUT &HC4,4:OUT &HC5,&H80
340 PRINT "T2 pre=";HEX$(P);" post=";HEX$(Q);
350 IF (P AND &HE0)=0 AND (Q AND &HE0)=&HA0 THEN PRINT " OK" ELSE PRINT " FAIL"
360 PRINT
370 PRINT "[4] OPL3 NEW + status doble"
380 OUT &HC6,5:OUT &HC7,1
390 PRINT "tras NEW=1: C4=";HEX$(INP(&HC4))
400 PRINT
410 PRINT "Pulsa tecla."
420 IF INKEY$="" THEN 420
